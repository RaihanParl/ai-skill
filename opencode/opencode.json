{
  "$schema": "https://opencode.ai/config.json",
  "instructions": [
    "AGENTS.md"
  ],
  "plugin": [
    "./plugins/caveman/plugin.js",
    "cursor-acp"
  ],
  "mcp": {
    "atlassian": {
      "type": "remote",
      "url": "https://mcp.atlassian.com/v1/mcp",
      "enabled": true,
      "oauth": {
        "scope": "read:jira:user-story read:jira-work write:jira-work read:confluence-space.summary read:confluence-content.summary read:confluence-content.all read:compass read:confluence-props read:confluence-content read:confluence-space read:confluence-content.permission read:jira:issue read:jira:project read:jira:user read:jira-sprint read:jira:board read:jira:issue-meta read:jira:issue-detail:remote-link read:jira:issue-detail:description read:jira:issue-detail:status read:jira:issue-detail:comment read:jira:issue-detail:attachment read:jira:issue-detail:vote read:jira:issue-detail:watcher read:jira:issue-detail:worklog read:jira:issue-detail:label read:jira:issue-detail:link read:jira:issue-detail:transition read:jira:issue-detail:assignee"
      }
    },
    "figma": {
      "type": "remote",
      "url": "https://mcp.figma.com/mcp"
    }
  },
  "provider": {
    "opencode": {
      "name": "OpenCode Zen",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "https://opencode.ai/zen/v1"
      },
      "models": {
        "deepseek-v4-flash-free": {
          "name": "DeepSeek V4 Flash Free"
        },
        "mimo-v2.5-free": {
          "name": "MiMo V2.5 Free"
        }
      }
    },
    "cursor-acp": {
      "name": "Cursor",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "http://127.0.0.1:32124/v1"
      },
      "models": {
        "auto": {
          "name": "Auto",
          "cost": {
            "input": 1.25,
            "output": 6,
            "cache_read": 0.25,
            "cache_write": 1.25
          }
        },
        "composer-1.5": {
          "name": "Composer 1.5",
          "cost": {
            "input": 3.5,
            "output": 17.5,
            "cache_read": 0.35,
            "cache_write": 3.5
          }
        },
        "composer-1": {
          "name": "Composer 1"
        },
        "opus-4.6": {
          "name": "Claude 4.6 Opus",
          "options": {
            "cursorModel": "opus-4.6"
          },
          "variants": {
            "thinking": {
              "cursorModel": "opus-4.6-thinking"
            }
          }
        },
        "sonnet-4.6": {
          "name": "Claude 4.6 Sonnet",
